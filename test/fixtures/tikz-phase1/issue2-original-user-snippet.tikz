\begin{tikzpicture}[scale=0.9, transform shape]
    % Caixa esquerda
    \fill[black!90] (-5.5, -2.5) rectangle (-0.5, 2.5);
    \node[white, font=\bfseries] at (-3.0, 2.2) {Sem matéria escura};
    \shade[ball color=white] (-3.0, 0) circle (0.35);
    \foreach \r/\op in {0.7/40, 1.1/30, 1.5/22, 1.9/15, 2.2/10} {
        \draw[white, opacity=\op/100, thick, rotate around={20:(-3.0,0)}] (-3.0, 0) ellipse (\r and \r*0.65);
    }
    \draw[->, ultra thick, white] (-1.3, -2.2) -- (-1.0, -2.2);
    \node[white, font=\scriptsize] at (-3.0, -2.2) {Distância $\rightarrow$};
    % Mini-curva: velocidade decaindo
    \draw[white!80, ultra thick] (-5.0, -1.8) .. controls (-4.5, -1.0) and (-3.0, -1.2) .. (-1.0, -2.0);

    % Caixa direita
    \fill[black!90] (0.5, -2.5) rectangle (5.5, 2.5);
    \node[white, font=\bfseries] at (3.0, 2.2) {Com matéria escura};
    \shade[ball color=white] (3.0, 0) circle (0.35);
    \foreach \r/\op in {0.7/40, 1.1/35, 1.5/30, 1.9/25, 2.2/22} {
        \draw[white, opacity=\op/100, thick, rotate around={20:(3.0,0)}] (3.0, 0) ellipse (\r and \r*0.65);
    }
    \draw[->, ultra thick, white] (4.7, -2.2) -- (5.0, -2.2);
    \node[white, font=\scriptsize] at (3.0, -2.2) {Distância $\rightarrow$};
    % Mini-curva: velocidade constante (plana)
    \draw[white!80, ultra thick] (1.0, -1.8) .. controls (1.5, -1.0) and (2.5, -1.1) .. (5.0, -1.15);
\end{tikzpicture}
