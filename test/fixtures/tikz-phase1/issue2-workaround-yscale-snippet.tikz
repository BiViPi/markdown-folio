\begin{tikzpicture}[scale=0.9, transform shape]
    % Caixa esquerda
    \fill[black!90] (-5.5, -2.5) rectangle (-0.5, 2.5);
    \node[white, font=\bfseries, yscale=-1] at (-3.0, -2.2) {Sem matéria escura};
    \shade[ball color=white] (-3.0, 0) circle (0.35);

    % Ellipses (normais, sem rotação)
    \draw[white!40, thick] (-3.0, 0) ellipse (0.7 and 0.455);
    \draw[white!30, thick] (-3.0, 0) ellipse (1.1 and 0.715);
    \draw[white!22, thick] (-3.0, 0) ellipse (1.5 and 0.975);
    \draw[white!15, thick] (-3.0, 0) ellipse (1.9 and 1.235);
    \draw[white!10, thick] (-3.0, 0) ellipse (2.2 and 1.43);

    \draw[->, ultra thick, white] (-1.3, 2.2) -- (-1.0, 2.2);
    \node[white, font=\scriptsize, yscale=-1] at (-3.0, 2.2) {Distância $\rightarrow$};
    % Mini-curva: velocidade decaindo
    \draw[white!80, ultra thick] (-5.0, 1.8) .. controls (-4.5, 1.0) and (-3.0, 1.2) .. (-1.0, 2.0);

    % Caixa direita
    \fill[black!90] (0.5, -2.5) rectangle (5.5, 2.5);
    \node[white, font=\bfseries, yscale=-1] at (3.0, -2.2) {Com matéria escura};
    \shade[ball color=white] (3.0, 0) circle (0.35);

    % Ellipses (normais, sem rotação)
    \draw[white!35, thick] (3.0, 0) ellipse (0.7 and 0.455);
    \draw[white!30, thick] (3.0, 0) ellipse (1.1 and 0.715);
    \draw[white!25, thick] (3.0, 0) ellipse (1.5 and 0.975);
    \draw[white!22, thick] (3.0, 0) ellipse (1.9 and 1.235);
    \draw[white!15, thick] (3.0, 0) ellipse (2.2 and 1.43);

    \draw[->, ultra thick, white] (4.7, 2.2) -- (5.0, 2.2);
    \node[white, font=\scriptsize, yscale=-1] at (3.0, 2.2) {Distância $\rightarrow$};
    % Mini-curva: velocidade constante (plana)
    \draw[white!80, ultra thick] (1.0, 1.8) .. controls (1.5, 1.0) and (2.5, 1.1) .. (5.0, 1.15);
\end{tikzpicture}
